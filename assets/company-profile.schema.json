{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jackterror/social-demand-signal-agent/blob/main/assets/company-profile.schema.json",
  "title": "Social Demand Signal Agent company profile",
  "type": "object",
  "required": [
    "schema_version",
    "profile_status",
    "company",
    "audience",
    "offer",
    "voice",
    "disclosure",
    "claims",
    "safety",
    "listening",
    "experiment"
  ],
  "properties": {
    "schema_version": {"const": 2},
    "profile_status": {"enum": ["setup", "demo", "ready"]},
    "company": {
      "type": "object",
      "required": ["name", "industry", "product", "description", "website"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "industry": {"type": "string", "minLength": 1},
        "product": {"type": "string", "minLength": 1},
        "description": {"type": "string", "minLength": 1},
        "website": {"type": "string", "format": "uri"}
      }
    },
    "audience": {
      "type": "object",
      "required": ["description", "pain_points", "intent_signals"],
      "properties": {
        "description": {"type": "string", "minLength": 1},
        "pain_points": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "intent_signals": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
      }
    },
    "offer": {
      "type": "object",
      "required": ["summary", "cta_url"],
      "properties": {
        "summary": {"type": "string", "minLength": 1},
        "cta_url": {"type": "string", "format": "uri"}
      }
    },
    "voice": {
      "type": "object",
      "required": ["attributes"],
      "properties": {
        "attributes": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
      }
    },
    "disclosure": {"type": "string", "minLength": 1},
    "claims": {
      "type": "object",
      "required": ["approved", "forbidden"],
      "properties": {
        "approved": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "forbidden": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
      }
    },
    "safety": {
      "type": "object",
      "required": ["exclusions", "escalation_terms", "max_responses_per_author_24h"],
      "properties": {
        "exclusions": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "escalation_terms": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "max_responses_per_author_24h": {"type": "integer", "minimum": 1}
      }
    },
    "listening": {
      "type": "object",
      "required": ["queries", "platforms", "freshness_minutes", "max_items"],
      "properties": {
        "queries": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "platforms": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "freshness_minutes": {"type": "integer", "minimum": 1},
        "max_items": {"type": "integer", "minimum": 1}
      }
    },
    "response_families": {"type": "array"},
    "experiment": {
      "type": "object",
      "required": ["primary_event", "guardrail_event", "minimum_sample_size"],
      "properties": {
        "primary_event": {"type": "string", "minLength": 1},
        "guardrail_event": {"type": "string", "minLength": 1},
        "minimum_sample_size": {"type": "integer", "minimum": 1}
      }
    }
  }
}
